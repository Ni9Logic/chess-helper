{
  "manifest_version": 3,
  "name": "Chess Trainer Overlay",
  "version": "0.1.0",
  "description": "Reads chess.com board, sends FEN to localhost trainer, overlays best move arrows.",
  "permissions": ["scripting", "tabs", "storage", "alarms"],
  "host_permissions": ["https://www.chess.com/*", "http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Chess Trainer",
    "default_popup": "popup.html"
  }
}
