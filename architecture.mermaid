    CS --> TAC
    CS --> MH --> ANA --> STORE
    CS -->|"≤7 pieces"| SYZYGY

    CONFIG <--> STORE
    UI <-->|"get/save config"| CONFIG
    CONFIG -->|"push"| CS
    CTX -->|"actions"| CS
